// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  NextAuth v5 required models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  surveys  Survey[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
//  Survey Builder models
// ─────────────────────────────────────────────

model Survey {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  slug        String       @unique
  isPublished Boolean      @default(false)
  isArchived  Boolean      @default(false)
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions    Question[]
  responses    Response[]
  analytics    SurveyAnalytics?
  interactions QuestionInteraction[]

  @@index([userId])
  @@map("surveys")
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
  CHECKBOX
  DROPDOWN
  RATING
  SCALE
  DATE
  EMAIL
  NUMBER
}

model Question {
  id          String       @id @default(cuid())
  surveyId    String
  type        QuestionType
  title       String
  description String?      @db.Text
  isRequired  Boolean      @default(false)
  order       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  survey  Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers Answer[]
  interactions QuestionInteraction[]

  @@index([surveyId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  label      String
  value      String
  order      Int
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@index([questionId])
  @@map("question_options")
}

model Response {
  id          String   @id @default(cuid())
  surveyId    String
  respondentId String?
  ipAddress   String?
  userAgent   String?  @db.Text
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  survey  Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([surveyId])
  @@map("responses")
}

model Answer {
  id         String   @id @default(cuid())
  responseId String
  questionId String
  optionId   String?
  value      String?  @db.Text
  createdAt  DateTime @default(now())

  response Response        @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   QuestionOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([responseId])
  @@index([questionId])
  @@map("answers")
}

model SurveyAnalytics {
  id              String   @id @default(cuid())
  surveyId        String   @unique
  totalViews      Int      @default(0)
  totalResponses  Int      @default(0)
  completionRate  Float    @default(0)
  avgCompletionTime Int    @default(0) // in seconds
  lastCalculated  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("survey_analytics")
}

// ─────────────────────────────────────────────
//  Drop-off tracking
// ─────────────────────────────────────────────

model QuestionInteraction {
  id            String   @id @default(cuid())
  surveyId      String
  questionId    String
  // Anonymous browser session — one UUID per survey page load
  sessionId     String
  questionIndex Int      // 0-based position in the survey
  timeSpent     Int      @default(0) // seconds on this question
  abandoned     Boolean  @default(false) // true if they left here
  createdAt     DateTime @default(now())

  survey   Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([surveyId])
  @@index([questionId])
  @@index([sessionId])
  @@map("question_interactions")
}
